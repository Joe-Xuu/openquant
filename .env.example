# ============================================================================
# OpenQuant — 环境配置 / Environment Configuration
# ============================================================================
# 使用方法 / Usage:
#   1. cp .env.example .env
#   2. 编辑 .env 填入你的 API 密钥 / Edit .env with your API keys
# ============================================================================

# ---------------------------------------------------------------------------
# 交易所模式 / Exchange Mode
# ---------------------------------------------------------------------------
# true  = 币安测试网 (模拟盘，无真实资金风险) / Binance Testnet (paper trading)
# false = 币安实盘 (真实资金，谨慎使用！) / Binance Live (real money - CAUTION!)
BINANCE_TESTNET=true

# ---------------------------------------------------------------------------
# 测试网 API 密钥 / Testnet API Keys
# ---------------------------------------------------------------------------
# 获取方式 / How to get:
#   1. 打开 https://testnet.binance.vision/
#   2. 用你的 GitHub 账号登录 / Login with GitHub
#   3. 点击 "Generate API Key" / Click "Generate API Key"
#   4. 复制 API Key 和 Secret Key 到下方 / Copy below
#
# 权限设置建议 / Recommended permissions:
#   ✅ Enable Spot & Margin Trading  (现货交易)
#   ❌ Enable Withdrawals           (不要开启提现权限！)
#   ✅ Enable Universal Transfer    (资金划转)
#
# 安全提示 / Security:
#   - 测试网资金是虚拟的，没有价值 / Testnet funds are fake, no real value
#   - 不要在测试网使用真实 API 密钥 / Never use real API keys on testnet
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here

# ---------------------------------------------------------------------------
# 实盘 API 密钥 / Live API Keys (仅当 BINANCE_TESTNET=false 时使用)
# ---------------------------------------------------------------------------
# 获取方式 / How to get:
#   1. 登录 https://www.binance.com/
#   2. 右上角头像 → API 管理 / Profile → API Management
#   3. 创建 API → 选择 "系统生成" / Create API → "System Generated"
#   4. 完成安全验证 / Complete security verification
#
# 权限设置 / Recommended permissions:
#   ✅ Enable Spot & Margin Trading
#   ❌ 不要开启提现权限！/ NEVER enable withdrawals!
#   ⚠️ 限制 API 访问 IP (推荐) / Restrict access to trusted IPs (recommended)
#
# 官方文档 / Official docs:
#   https://www.binance.com/zh-CN/support/faq/detail/ab78f9a1b8824cf0a106b4229c76496d
BINANCE_API_KEY=your_live_api_key_here
BINANCE_API_SECRET=your_live_api_secret_here

# ---------------------------------------------------------------------------
# 交易参数 / Trading Parameters
# ---------------------------------------------------------------------------
INITIAL_CAPITAL=10000
MAX_POSITION_SIZE_PCT=20
MAX_DRAWDOWN_PCT=15
MAX_DAILY_LOSS_PCT=5

# ---------------------------------------------------------------------------
# 数据库 & 日志 / Database & Logging
# ---------------------------------------------------------------------------
DB_PATH=data/trading_ledger.db
LOG_LEVEL=INFO
LOG_FILE=logs/trading_system.log
