# ============================================================================
# OpenQuant — 环境配置 / Environment Configuration
# ============================================================================
# 使用方法 / Usage:
#   1. cp .env.example .env
#   2. 编辑 .env 填入你的 API 密钥 / Edit .env with your API keys
# ============================================================================

# ---------------------------------------------------------------------------
# 交易所模式 / Exchange Mode
# ---------------------------------------------------------------------------
# BINANCE_TESTNET: true=测试网, false=实盘
#   true  = Binance Testnet (paper trading, fake money)
#   false = Binance Live (real money — USE WITH CAUTION!)
BINANCE_TESTNET=true

# BINANCE_MARKET: 现货还是合约
#   spot    = 现货 (适用: 网格做多, 回测最优, 风险低)
#   futures = 合约 (适用: 网格+做空, 有杠杆, 风险高)
#   ⚠️ 建议先用 spot 测试, 确认系统稳定后再切 futures
BINANCE_MARKET=spot

# ---------------------------------------------------------------------------
# 现货测试网 API 密钥 / Spot Testnet API Keys
# ---------------------------------------------------------------------------
# 获取方式 / How to get:
#   1. 打开 https://testnet.binance.vision/
#   2. 用 GitHub 登录 → 点击 "Generate API Key"
#   3. 复制 API Key 和 Secret Key 到下方
# 权限: ✅ Spot Trading 即可
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here

# ---------------------------------------------------------------------------
# 合约测试网 API 密钥 / Futures Testnet API Keys
# ---------------------------------------------------------------------------
# 获取方式 / How to get:
#   1. 打开 https://testnet.binancefuture.com/
#   2. 用 GitHub 登录 → 点击 "Generate API Key"
#   3. 复制 API Key 和 Secret Key
# 权限: ✅ Futures Trading 即可
# ⚠️ 合约和现货的测试网是分开的, 需要分别注册
BINANCE_FUTURES_API_KEY=your_futures_testnet_key_here
BINANCE_FUTURES_API_SECRET=your_futures_testnet_secret_here

# ---------------------------------------------------------------------------
# 实盘 API 密钥 / Live API Keys (BINANCE_TESTNET=false 时使用)
# ---------------------------------------------------------------------------
# 现货: https://www.binance.com/ → 头像 → API 管理 → 创建 API
# 合约: https://www.binance.com/ → 合约 → API 管理
# 权限: ✅ 开启交易 ❌ 不要开启提现 ⚠️ 限制访问 IP
# 文档: https://www.binance.com/zh-CN/support/faq/detail/ab78f9a1b8824cf0a106b4229c76496d
BINANCE_API_KEY=your_live_api_key_here
BINANCE_API_SECRET=your_live_api_secret_here

# ---------------------------------------------------------------------------
# 交易参数 / Trading Parameters
# ---------------------------------------------------------------------------
INITIAL_CAPITAL=10000
MAX_POSITION_SIZE_PCT=70
MAX_DRAWDOWN_PCT=15
MAX_DAILY_LOSS_PCT=5

# ---------------------------------------------------------------------------
# PostgreSQL 数据库 / Database (Production Grade)
# ---------------------------------------------------------------------------
PG_HOST=localhost
PG_PORT=5432
PG_USER=openquant
PG_PASSWORD=openquant
PG_DB=openquant

# ---------------------------------------------------------------------------
# 日志 / Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/trading_system.log
